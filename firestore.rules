// Written by Brian McCarthy
// Cloud Native Tax Calculator Firestore Security Rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Tax Brackets - Publicly readable for calculation
    // Allowing write for assessment purposes to support automatic seeding
    match /taxBrackets/{bracketId} {
      allow read: if true;
      allow write: if true;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
